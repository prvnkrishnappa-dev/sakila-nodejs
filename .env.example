# ─────────────────────────────────────────────────────────────────────────────
# Sakila REST API — Environment Variables
# Copy to .env and fill in values for your environment.
# See CONFIG.md for full documentation.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────

# Runtime environment. Controls logging format, SQL verbosity, error masking.
# Valid: development | production | test
# Default: development
# REQUIRED in production containers: must be set to "production"
NODE_ENV=development

# TCP port the server will listen on.
# Type: integer  Range: 1–65535  Default: 8080
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────

# MySQL host.  Default: localhost
DB_HOST=localhost

# MySQL port.  Type: integer  Default: 3306
DB_PORT=3306

# Database name.  Default: sakila
DB_NAME=sakila

# Database user.  Default: root
DB_USER=root

# Database password.
#   production: REQUIRED, minimum 8 characters, must not be a placeholder
#   development/test: optional (empty string allowed)
DB_PASSWORD=

# Connection pool — tuned for typical web application workloads.
DB_POOL_MAX=10          # max simultaneous connections
DB_POOL_MIN=2           # min idle connections kept warm
DB_POOL_ACQUIRE_MS=30000  # ms to wait for a free connection before error
DB_POOL_IDLE_MS=10000     # ms a connection sits idle before being released

# Startup connectivity retry (exponential backoff).
# Critical for container orchestration (Docker Compose, Kubernetes).
DB_CONNECT_RETRIES=5     # number of attempts before giving up
DB_CONNECT_RETRY_MS=2000 # base delay; doubles each attempt (2s → 4s → 8s …)

# ── Security ──────────────────────────────────────────────────────────────────

# Allowed CORS origin(s).
#   Empty string (default) = block all cross-origin requests.
#   Single origin:  CORS_ORIGIN=https://app.example.com
#   Multiple (comma-separated): CORS_ORIGIN=https://app.example.com,https://admin.example.com
#   Must be valid http/https URLs — not wildcard '*'.
CORS_ORIGIN=

# Read (GET) rate limit — requests per IP per window.
RATE_LIMIT_READ_WINDOW_MS=60000   # 1 minute
RATE_LIMIT_READ_MAX=300           # 300 reads per minute

# Write (POST/PUT/DELETE) rate limit — requests per IP per window.
RATE_LIMIT_WRITE_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_WRITE_MAX=60           # 60 writes per minute

# ── Observability ─────────────────────────────────────────────────────────────

# Winston log level.
# Valid: error | warn | info | http | verbose | debug | silly
# Default: http (captures Morgan access logs + info/warn/error)
# Production recommendation: info (omits HTTP and debug lines)
LOG_LEVEL=http

# ── Shutdown ──────────────────────────────────────────────────────────────────

# Time (ms) to wait for graceful shutdown before forcing process.exit(1).
# Should exceed the longest expected in-flight request duration.
# Default: 10000 (10 seconds)
SHUTDOWN_TIMEOUT_MS=10000
