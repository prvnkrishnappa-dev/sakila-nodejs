{
  "name": "sakila-rest-api",
  "version": "10.0.0",
  "description": "Production-grade Node.js REST API — Sakila DVD rental database",
  "main": "server.js",
  "scripts": {
    "start":         "node server.js",
    "dev":           "nodemon server.js",
    "test":          "jest --runInBand --forceExit",
    "test:watch":    "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "lint":          "eslint . --ext .js"
  },
  "dependencies": {
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":             "^7.1.0",
    "joi":                "^17.13.1",
    "morgan":             "^1.10.0",
    "mysql2":             "^3.9.8",
    "sequelize":          "^6.37.3",
    "uuid":               "^10.0.0",
    "winston":            "^3.13.0"
  },
  "devDependencies": {
    "jest":      "^29.7.0",
    "nodemon":   "^3.1.3",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/tests/**/*.test.js"],
    "clearMocks":      true,
    "resetMocks":      true,
    "restoreMocks":    true,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "services/**/*.js",
      "repositories/**/*.js",
      "middleware/**/*.js",
      "errors/**/*.js",
      "config/**/*.js"
    ]
  },
  "engines": { "node": ">=18.0.0" }
}
